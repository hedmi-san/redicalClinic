<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootVBox" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.WorkerFormController"
      spacing="0" style="-fx-background-color: #f4f6f9;">

    <VBox styleClass="form-container" spacing="10" VBox.vgrow="ALWAYS">
        <Label fx:id="lblTitle" text="Détails de l'Employé" styleClass="form-title" />

        <GridPane hgap="20" vgap="15">
            <columnConstraints>
                <ColumnConstraints minWidth="160" />
                <ColumnConstraints minWidth="250" hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Nom et Prénom:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label" />
            <TextField fx:id="txtName" GridPane.rowIndex="0" GridPane.columnIndex="1" />

            <Label text="Date de Naissance:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label" />
            <DatePicker fx:id="dpBirthDate" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity" />

            <Label text="Lieu de Naissance:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label" />
            <TextField fx:id="txtBirthPlace" GridPane.rowIndex="2" GridPane.columnIndex="1" />

            <Label text="Numéro de Téléphone:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label" />
            <TextField fx:id="txtPhone" GridPane.rowIndex="3" GridPane.columnIndex="1" />

            <Label text="N° Carte d'Identité:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label" />
            <TextField fx:id="txtIdCard" GridPane.rowIndex="4" GridPane.columnIndex="1" />

            <Label text="Fonction:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label" />
            <TextField fx:id="txtFunction" GridPane.rowIndex="5" GridPane.columnIndex="1" />

            <Label text="Situation Familiale:" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="form-label" />
            <TextField fx:id="txtFamilySituation" GridPane.rowIndex="6" GridPane.columnIndex="1" />
        </GridPane>

        <Region VBox.vgrow="ALWAYS" minHeight="20" />

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button text="Annuler" styleClass="secondary-button" onAction="#handleCancel" />
            <Button text="Enregistrer" styleClass="primary-button" onAction="#handleSave" />
        </HBox>
    </VBox>

</VBox>
