<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" styleClass="root-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">
    <stylesheets>
        <URL value="@../../css/pages/dashboard.css" />
    </stylesheets>
    <VBox spacing="0" styleClass="dashboard-container">
        
        <!-- Header & Selectors -->
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="dashboard-header">
            <VBox HBox.hgrow="ALWAYS">
                <Label styleClass="page-title" text="🏠 Tableau de Bord" />
                <Label styleClass="page-subtitle" text="Aperçu des performances de la clinique" />
            </VBox>
            
            <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="selector-container">
                <ComboBox fx:id="monthSelector" promptText="Mois" />
                <ComboBox fx:id="yearSelector" promptText="Année" />
            </HBox>
        </HBox>

        <!-- Summary Cards Grid -->
        <FlowPane hgap="25" vgap="25" styleClass="summary-grid">
            
            <!-- Sessions Count -->
            <VBox styleClass="summary-card, card-sessions">
                <HBox alignment="TOP_RIGHT">
                     <StackPane styleClass="card-icon-container">
                        <Label text="📅" styleClass="card-icon"/>
                    </StackPane>
                </HBox>
                <VBox styleClass="card-info">
                    <Label text="Sessions" styleClass="card-title" />
                    <HBox alignment="BASELINE_LEFT">
                        <Label fx:id="sessionCountLabel" text="0" styleClass="card-value" />
                        <Label text="Séances" styleClass="card-unit" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Expected Profit (Total Cost) -->
            <VBox fx:id="expectedProfitCard" styleClass="summary-card, card-expected">
                <HBox alignment="TOP_RIGHT">
                     <StackPane styleClass="card-icon-container">
                        <Label text="💰" styleClass="card-icon"/>
                    </StackPane>
                </HBox>
                <VBox styleClass="card-info">
                    <Label text="Profit Attendu" styleClass="card-title" />
                    <HBox alignment="BASELINE_LEFT">
                        <Label fx:id="expectedProfitLabel" text="0.00" styleClass="card-value" />
                        <Label text="DZD" styleClass="card-unit" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Actual Profit (Paid Amount) -->
            <VBox fx:id="actualProfitCard" styleClass="summary-card, card-actual">
                <HBox alignment="TOP_RIGHT">
                     <StackPane styleClass="card-icon-container">
                        <Label text="💳" styleClass="card-icon"/>
                    </StackPane>
                </HBox>
                <VBox styleClass="card-info">
                    <Label text="Profit Réalisé" styleClass="card-title" />
                    <HBox alignment="BASELINE_LEFT">
                        <Label fx:id="actualProfitLabel" text="0.00" styleClass="card-value" />
                        <Label text="DZD" styleClass="card-unit" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Balance -->
            <VBox styleClass="summary-card, card-balance">
                <HBox alignment="TOP_RIGHT">
                     <StackPane styleClass="card-icon-container">
                        <Label text="⚖️" styleClass="card-icon"/>
                    </StackPane>
                </HBox>
                <VBox styleClass="card-info">
                    <Label text="Reste à percevoir" styleClass="card-title" />
                    <HBox alignment="BASELINE_LEFT">
                        <Label fx:id="balanceLabel" text="0.00" styleClass="card-value" />
                        <Label text="DZD" styleClass="card-unit" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Worker Payments -->
            <VBox styleClass="summary-card, card-workers">
                <HBox alignment="TOP_RIGHT">
                     <StackPane styleClass="card-icon-container">
                        <Label text="👥" styleClass="card-icon"/>
                    </StackPane>
                </HBox>
                <VBox styleClass="card-info">
                    <Label text="Paiement Employés" styleClass="card-title" />
                    <HBox alignment="BASELINE_LEFT">
                        <Label fx:id="workerPaymentsLabel" text="0.00" styleClass="card-value" />
                        <Label text="DZD" styleClass="card-unit" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Bills -->
            <VBox styleClass="summary-card, card-bills">
                <HBox alignment="TOP_RIGHT">
                     <StackPane styleClass="card-icon-container">
                        <Label text="🧾" styleClass="card-icon"/>
                    </StackPane>
                </HBox>
                <VBox styleClass="card-info">
                    <Label text="Dépenses / Factures" styleClass="card-title" />
                    <HBox alignment="BASELINE_LEFT">
                        <Label fx:id="billsLabel" text="0.00" styleClass="card-value" />
                        <Label text="DZD" styleClass="card-unit" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Sales -->
            <VBox styleClass="summary-card, card-sales">
                <HBox alignment="TOP_RIGHT">
                     <StackPane styleClass="card-icon-container">
                        <Label text="🛒" styleClass="card-icon"/>
                    </StackPane>
                </HBox>
                <VBox styleClass="card-info">
                    <Label text="Revenus Ventes" styleClass="card-title" />
                    <HBox alignment="BASELINE_LEFT">
                        <Label fx:id="salesLabel" text="0.00" styleClass="card-value" />
                        <Label text="DZD" styleClass="card-unit" />
                    </HBox>
                </VBox>
            </VBox>

        </FlowPane>
    </VBox>
</ScrollPane>
