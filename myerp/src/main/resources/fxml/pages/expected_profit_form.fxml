<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ExpectedProfitFormController"
      styleClass="modal" spacing="20" prefWidth="700" prefHeight="500">
    <stylesheets>
        <URL value="@../../css/pages/dashboard.css" />
        <URL value="@../../css/pages/patient.css" />
    </stylesheets>

    <HBox alignment="CENTER_LEFT">
        <Label text="💰 Détails Profit Attendu" styleClass="modal-title" />
    </HBox>

    <!-- Filters Row -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <VBox spacing="6">
            <Label text="DATE" styleClass="form-label" />
            <DatePicker fx:id="datePicker" styleClass="form-control" promptText="Sélectionnez une date" />
        </VBox>
        <VBox spacing="6">
            <Label text="SEXE" styleClass="form-label" />
            <ComboBox fx:id="genderFilter" styleClass="form-control" promptText="Filtrer par sexe" prefWidth="160" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <VBox spacing="6" alignment="CENTER_RIGHT">
            <Label text="TOTAL" styleClass="form-label" />
            <Label fx:id="totalLabel" text="0.00 DZD" styleClass="card-value" style="-fx-font-size: 18;" />
        </VBox>
    </HBox>

    <Label text="Séances Normales" styleClass="form-label" />
    <TableView fx:id="resultTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="patientNameColumn" text="Nom du Patient" prefWidth="220" />
            <TableColumn fx:id="treatmentColumn" text="Traitement" prefWidth="250" />
            <TableColumn fx:id="costColumn" text="Coût (DZD)" prefWidth="150" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <Label text="Plans Thérapeutiques" styleClass="form-label" />
    <TableView fx:id="therapyPlanTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="tpPatientNameColumn" text="Nom du Patient" prefWidth="350" />
            <TableColumn fx:id="tpCostColumn" text="Coût (DZD)" prefWidth="150" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

</VBox>