<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PatientDetailController" 
      prefWidth="800.0" prefHeight="600.0" styleClass="main-content">
    <stylesheets>
        <URL value="@../../css/pages/patient.css" />
    </stylesheets>

    <!-- Hero Section -->
    <HBox fx:id="heroSection" styleClass="hero-header" alignment="CENTER_LEFT" spacing="24">
        <Label fx:id="heroInitials" text="JD" styleClass="initials-avatar" />
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="heroName" text="Nom du Patient" styleClass="hero-name" />
            <Label fx:id="heroPhone" text="Téléphone" styleClass="hero-phone" />
        </VBox>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Imprimer La facture" onAction="#printPatientBill" styleClass="btn-ghost"/>
            <Button text="Modifier Infos" onAction="#handleEditPatient" styleClass="btn-ghost" />
            <Button text="Supprimer Patient" onAction="#handleDeletePatient" styleClass="btn-ghost" style="-fx-text-fill: #e11d48;" />
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="profile-scroll">
        <VBox spacing="0">
            <!-- Financial Stats -->
            <HBox spacing="20" styleClass="fin-cards-grid">
                <VBox styleClass="fin-card" HBox.hgrow="ALWAYS">
                    <Label text="COÛT TOTAL" styleClass="fc-label" />
                    <Label fx:id="totalCostLabel" text="0.00 DZD" styleClass="fc-value, fc-teal" />
                </VBox>
                <VBox styleClass="fin-card" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL PAYÉ" styleClass="fc-label" />
                    <Label fx:id="totalPaidLabel" text="0.00 DZD" styleClass="fc-value, fc-green" />
                </VBox>
                <VBox styleClass="fin-card" HBox.hgrow="ALWAYS">
                    <Label text="SOLDE" styleClass="fc-label" />
                    <Label fx:id="balanceLabel" text="0.00 DZD" styleClass="fc-value, fc-rose" />
                </VBox>
            </HBox>

            <!-- Session History -->
            <VBox styleClass="sessions-area" spacing="24">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Historique des séances" styleClass="section-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="+ Ajouter une séance" onAction="#handleAddSession" styleClass="btn-teal" />
                </HBox>
                
                <VBox fx:id="sessionsContainer" spacing="16" />
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
